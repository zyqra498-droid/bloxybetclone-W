# ═══════════════════════════════════════════════════════════════════════════
# Copy to `.env` at the repo root for local dev. On Render/hosting, add these
# in the dashboard (Environment / Variables) — they are NOT committed.
# ═══════════════════════════════════════════════════════════════════════════

# --- Frontend (NEXT_PUBLIC_* is embedded in the browser bundle) ---
# Leave unset in production to use same-origin `/api/*` (Next.js rewrites to the backend).
# Set only if the API is on another domain.
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_SOCKET_URL=
NEXT_PUBLIC_SITE_NAME=RobloxBet

# --- URLs (public site — used for CORS + cookies; use your real deploy URL in production) ---
# Example Render: https://your-app.onrender.com
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# --- Backend process ---
NODE_ENV=development
# Backend listens on this port. Root `npm run start` forces 4000 for the API so Next can use $PORT.
PORT=4000

# --- Database & Redis (production: use managed Postgres + Redis from your host) ---
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/roblox_gamble?schema=public
REDIS_URL=redis://127.0.0.1:6379

# --- Secrets (generate long random strings — openssl rand -hex 32) ---
JWT_SECRET=replace-with-at-least-32-characters-random-string
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000
CSRF_SECRET=replace-with-at-least-32-characters-random-string
ENCRYPTION_KEY=replace-with-at-least-32-characters-random-string
TRADE_HMAC_SECRET=replace-with-at-least-16-chars

# --- Game / trade tuning ---
BIO_CHALLENGE_TTL_SEC=900
# false for real Roblox trades; true to simulate trades on the site only
MOCK_ROBLOX_TRADES=false
# true = market can credit catalog items without Roblox (dev/feature flag)
CATALOG_INSTANT_DEPOSIT=true

# Optional: trade bot synced into DB on API startup (never commit real cookies)
# TRADE_BOT_ROBLOX_USERNAME=YourBotUsername
# TRADE_BOT_ROBLOX_USER_ID=1234567890
# TRADE_BOT_COOKIE=.ROBLOSECURITY=_|WARNING...
