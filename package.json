{
  "name": "roblox-gamble-platform",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "setup": "node scripts/setup-dev.mjs",
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w backend && npm run build -w frontend",
    "build:frontend:cpu-prof": "npm run build:cpu-prof -w frontend",
    "start": "concurrently -n api,web \"cross-env PORT=4000 npm run start -w backend\" \"npm run start -w frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "prisma": "5.22.0",
    "tsx": "^4.19.2",
    "wait-on": "^8.0.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
